# LLM Provider: anthropic | openai | gemini | openrouter
LLM_PROVIDER=anthropic

# Anthropic (default)
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-5

# OpenAI
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# Google Gemini
# GOOGLE_API_KEY=AIza...
# LLM_MODEL=gemini-2.0-flash

# OpenRouter
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_SITE_URL=http://localhost:3000
# OPENROUTER_SITE_NAME=Storyboard App
# LLM_MODEL=anthropic/claude-3.5-sonnet

# Image generation
IMAGE_GEN_PROVIDER=imagen
GOOGLE_PROJECT_ID=my-project
GOOGLE_LOCATION=us-central1
GOOGLE_MODEL=gemini-2.5-flash-image
# GOOGLE_APPLICATION_CREDENTIALS=./gcp-credentials.json

# Video generation
VIDEO_GEN_PROVIDER=veo
GROK_AUTH_STATE=./auth/grok_state.json

# Browser automation
HEADLESS_BROWSER=false
IMAGE_GEN_TIMEOUT=120000
VIDEO_GEN_TIMEOUT=300000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# App
PORT=3001
FRONTEND_URL=http://localhost:5173
OUTPUT_DIR=./output
PROMPTS_DIR=../prompts

# LangGraph persistence (memory | sqlite)
LANGGRAPH_CHECKPOINTER=memory
